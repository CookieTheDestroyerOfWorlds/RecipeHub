{
  "name": "recipehub",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter @recipehub/web drizzle-kit generate",
    "db:push": "pnpm --filter @recipehub/web drizzle-kit push",
    "db:migrate": "pnpm --filter @recipehub/web drizzle-kit migrate",
    "db:studio": "pnpm --filter @recipehub/web drizzle-kit studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
