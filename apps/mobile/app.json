{
  "expo": {
    "name": "RecipeHub",
    "slug": "recipehub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "recipehub",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#d97706"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.recipehub.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#d97706"
      },
      "package": "com.recipehub.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "RecipeHub needs access to your photos to upload recipe images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
